<?xml version="1.0" encoding="utf-8"?><androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"    android:orientation="vertical"    android:background="@color/black"    android:padding="20dp"    android:layout_width="match_parent"    android:layout_height="wrap_content">    <TextView        android:id="@+id/info_text"        android:layout_width="match_parent"        android:layout_height="wrap_content"        android:text="@string/info_text"        android:textColor="@color/white"        android:fontFamily="@font/poppins_regular"        android:textSize="20sp"        app:layout_constraintTop_toTopOf="parent"/>    <TextView        android:id="@+id/version"        android:layout_width="match_parent"        android:layout_height="wrap_content"        android:text="@string/creator"        android:textColor="@color/white"        android:fontFamily="@font/poppins_medium"        android:textSize="20sp"        android:layout_marginTop="10dp"        app:layout_constraintTop_toBottomOf="@id/info_text"/>    <Button        android:id="@+id/close_btn"        android:layout_width="wrap_content"        android:layout_height="wrap_content"        android:text="ok"        android:padding="10dp"        android:backgroundTint="@color/green"        app:layout_constraintBottom_toBottomOf="parent"        app:layout_constraintRight_toRightOf="parent"        android:layout_marginRight="20dp"        app:layout_constraintTop_toBottomOf="@id/version"/></androidx.constraintlayout.widget.ConstraintLayout>