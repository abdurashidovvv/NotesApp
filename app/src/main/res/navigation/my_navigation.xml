<?xml version="1.0" encoding="utf-8"?><navigation xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"    xmlns:tools="http://schemas.android.com/tools"    android:id="@+id/my_navigation"    app:startDestination="@id/homeFragment">    <fragment        android:id="@+id/homeFragment"        android:name="com.abdurashidov.notesapp.fragments.HomeFragment"        android:label="fragment_home"        tools:layout="@layout/fragment_home" >        <action            android:id="@+id/action_homeFragment_to_addNoteFragment"            app:destination="@id/addNoteFragment" />        <action            android:id="@+id/action_homeFragment_to_updateNoteFragment"            app:destination="@id/updateNoteFragment" />    </fragment>    <fragment        android:id="@+id/addNoteFragment"        android:name="com.abdurashidov.notesapp.fragments.AddNoteFragment"        android:label="fragment_add_note"        tools:layout="@layout/fragment_add_note" />    <fragment        android:id="@+id/updateNoteFragment"        android:name="com.abdurashidov.notesapp.fragments.UpdateNoteFragment"        android:label="UpdateNoteFragment" /></navigation>